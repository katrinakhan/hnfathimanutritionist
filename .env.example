# Copy this file to .env and fill in your Stripe test keys from:
# https://dashboard.stripe.com/test/apikeys

SECRET_KEY=change-this-to-a-long-random-string

# Stripe test secret key (starts with sk_test_...)
STRIPE_SECRET_KEY=sk_test_your_key_here

# Optional: your live site URL when deployed (e.g. https://your-app.onrender.com)
# Leave blank for local http://127.0.0.1:5000
PUBLIC_BASE_URL=
